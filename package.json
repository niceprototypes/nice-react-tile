    "styled-components",
    "responsive",
    "component"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "nice-react-flex": ">=2.0.0",
    "nice-react-typography": ">=5.0.0",
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0",
    "styled-components": ">=6.1.18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.32.2",
    "jest": "^29.5.0",
    "nice-configuration": "file:../configuration",
    "nice-react-flex": "file:../react-flex",
    "nice-react-typography": "file:../react-typography",
    "react": "^19.2.0",
    "react-is": "^19.2.0",
    "rollup": "^4.9.1",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "styled-components": "^6.1.19",
    "tslib": "^2.6.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niceprototypes/nice-react-tile.git"
  },
  "bugs": {
    "url": "https://github.com/niceprototypes/nice-react-tile/issues"
